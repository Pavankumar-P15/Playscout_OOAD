# Server
PORT=8080

# Supabase Postgres
DB_URL=jdbc:postgresql://YOUR_SUPABASE_HOST:5432/postgres?sslmode=require&prepareThreshold=0
DB_USER=YOUR_SUPABASE_DB_USER
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# Connection pool
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_TIMEOUT=30000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
